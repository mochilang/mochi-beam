{hex, [
  {name, mochi_runtime},
  {files, ["src", "include", "LICENSE", "README.md", "rebar.config"]},
  {licenses, ["Apache-2.0"]},
  {links, [{"GitHub", "https://github.com/mochilang/mochi"}]},
  {description, "Mochi BEAM runtime library (mochi_fetch, mochi_json, mochi_llm, mochi_async, mochi_stream)"}
]}.

{profiles, [
  {test, [
    {erl_opts, [debug_info]},
    {deps, []}
  ]}
]}.
